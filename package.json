{
  "name": "ai-first-nextjs-boilerplate",
  "version": "1.0.0",
  "private": false,
  "author": "Noah Duong",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "keywords": [
    "next",
    "boilerplate",
    "ai-first",
    "noahduong",
    "typescript",
    "pandacss",
    "ark-ui",
    "tanstack-query",
    "zustand",
    "react-hook-form",
    "zod",
    "vitest"
  ],
  "scripts": {
    "dev": "vinext dev",
    "dev:next": "next dev --turbo",
    "build": "vinext build",
    "build:next": "next build",
    "start": "vinext start",
    "start:next": "node .next/standalone/server.js",
    "start:dev": "vinext dev",
    "deploy": "vinext deploy",
    "lint": "vinext lint",
    "lint:biome": "biome check --write .",
    "format": "biome format --write .",
    "lint-staged": "lint-staged",
    "prepare": "panda codegen && (husky || true)",
    "postinstall": "node .husky/install.mjs || true; command -v pr-agent >/dev/null 2>&1 || echo '\\n⚠️  pr-agent not found. Run: pip install pr-agent (or ./scripts/setup-ai.sh for full AI setup)\\n'",
    "build:development": "make build-development",
    "start:development": "make start-development",
    "build:staging": "make build-staging",
    "start:staging": "make start-staging",
    "build:production": "make build-production",
    "start:production": "make start-production",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:check": "vitest",
    "validate_branch": "sh .husky/validate-branch.sh",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true vinext build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "ai:setup": "bash scripts/setup-ai.sh",
    "ai:sync": "bash scripts/sync-ai.sh",
    "ai:gen": "bash scripts/gen-ai-config.sh",
    "ai:metrics": "bash scripts/ai-metrics.sh",
    "wrangler:types": "wrangler types"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/nextjs": "10.59.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "camelcase-keys": "10.0.2",
    "consola": "^3.4.2",
    "date-fns": "4.4.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "next-safe-action": "^8.5.5",
    "nuqs": "^2.8.9",
    "ofetch": "^1.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "server-only": "^0.0.1",
    "sharp": "^0.35.2",
    "snakecase-keys": "9.0.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@cloudflare/vite-plugin": "1.42.1",
    "@cloudflare/workers-types": "4.20260621.1",
    "@next/bundle-analyzer": "16.2.9",
    "@pandacss/dev": "1.11.3",
    "@playwright/test": "1.61.0",
    "@tanstack/eslint-plugin-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitejs/plugin-rsc": "0.5.27",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "msw": "2.14.6",
    "postcss": "^8.5.15",
    "react-scan": "0.5.7",
    "react-server-dom-webpack": "19.2.7",
    "typescript": "^6.0.3",
    "vinext": "0.1.6",
    "vite": "8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "wrangler": "4.103.0"
  }
}
