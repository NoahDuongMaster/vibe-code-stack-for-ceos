{
  "name": "vibe-code-stack-for-ceos",
  "version": "1.1.0",
  "private": true,
  "author": "Noah Duong",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11"
  },
  "keywords": [
    "next",
    "boilerplate",
    "ai-first",
    "noahduong",
    "typescript",
    "pandacss",
    "ark-ui",
    "tanstack-query",
    "zustand",
    "react-hook-form",
    "zod",
    "vitest",
    "monorepo",
    "turborepo",
    "connect-rpc",
    "microservices",
    "rsbuild",
    "astro",
    "cloudflare-workers"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@repo/web",
    "dev:landing": "turbo run dev --filter=@repo/landing",
    "dev:admin": "turbo run dev --filter=@repo/admin",
    "dev:api": "turbo run dev --filter=@repo/api-node",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@repo/web",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage --filter=@repo/web",
    "test:e2e": "pnpm --filter @repo/web test:e2e",
    "deploy:web": "turbo run deploy --filter=@repo/web",
    "deploy:admin": "turbo run deploy --filter=@repo/admin",
    "deploy:landing": "turbo run deploy --filter=@repo/landing",
    "deploy:gateway": "turbo run deploy --filter=@repo/gateway-cf",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "postinstall": "node .husky/install.mjs || true",
    "lint-staged": "lint-staged",
    "validate_branch": "sh .husky/validate-branch.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.3.3",
    "typescript": "catalog:"
  }
}
