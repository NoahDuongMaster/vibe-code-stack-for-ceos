# DO NOT ADD SECRETS TO THIS FILE.
# Use `.env.production.local` for secrets (auto-detected by docker-compose).

# --- Public (client-safe) ---
NEXT_PUBLIC_PROJECT_NAME="nextjs_boilerplate"
NEXT_PUBLIC_API_ENDPOINT=https://api.example.com
NEXT_PUBLIC_BASE_URL=https://example.com
NEXT_PUBLIC_CORS_COOKIE=.example.com

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=

# --- Server-only (never exposed to browser) ---
SESSION_SECRET=generate-a-32-char-random-string-here
CORS_ORIGIN=*.example.com,example.com
CORS_RESOURCE=cdn.example.com
ANALYZE=false
