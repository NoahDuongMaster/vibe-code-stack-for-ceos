{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [
    "tsconfig.base.json",
    "biome.json",
    ".npmrc",
    "pnpm-workspace.yaml"
  ],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "NEXT_PUBLIC_*",
        "PUBLIC_*",
        "SESSION_SECRET",
        "DEMO_AUTH_EMAIL",
        "DEMO_AUTH_PASSWORD",
        "CORS_*",
        "SENTRY_*"
      ]
    },
    "typecheck": {},
    "lint": {},
    "test": {},
    "test:coverage": {
      "outputs": ["coverage/**"]
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": [
        "CLOUDFLARE_API_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID",
        "WRANGLER_*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
