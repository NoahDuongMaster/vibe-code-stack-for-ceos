# api-node (Connect RPC over Node.js) — copy to `.env` for local overrides.
# `.env` is git-ignored; this sample is safe to commit.

# Port the Connect/gRPC server listens on (default: 3001).
PORT=3001

# Comma-separated list of allowed CORS origins for browser clients (e.g. the
# admin SPA). '*' allows any origin. Leave unset to disable CORS entirely.
# Defense-in-depth only when reached via services/api-gateway — the gateway
# re-stamps every proxied response with ITS OWN CORS_ORIGINS decision
# (overriding whatever this service sends), so it is the single CORS
# authority for browser clients. This only matters if api-node is ever
# exposed directly (bypassing the gateway).
CORS_ORIGINS=

# Rejects requests whose Content-Length exceeds this many bytes (default: 5 MB).
MAX_BODY_BYTES=5242880

# Socket idle timeout in ms (default: 30000).
REQUEST_TIMEOUT_MS=30000

# Best-effort per-instance rate limit (requests per client per window) — see
# src/rate-limit.ts. Defense-in-depth only; the real limit should be enforced
# in front of this service (services/api-gateway's RATE_LIMITER binding, or a
# LB/WAF), since this does not coordinate across replicas.
RATE_LIMIT=300
RATE_LIMIT_WINDOW_MS=60000

# Sentry DSN for crash reporting. Unset disables Sentry entirely.
SENTRY_DSN=
