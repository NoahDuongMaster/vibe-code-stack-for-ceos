#!/bin/sh
# Tag commits made during an active Claude Code / AI session.
# Marker file is created by the SessionStart hook in .claude/settings.json.
# This enables ai-metrics.sh to distinguish AI-assisted vs manual commits.

COMMIT_MSG_FILE="$1"
MARKER="/tmp/ai-session-$(date +%Y%m%d).marker"

if [ -f "$MARKER" ] && [ -f "$COMMIT_MSG_FILE" ]; then
  if ! grep -q "^AI-Session:" "$COMMIT_MSG_FILE"; then
    printf '\nAI-Session: true\n' >> "$COMMIT_MSG_FILE"
  fi
fi
