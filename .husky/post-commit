#!/bin/sh

# Update code-review-graph in background after each commit
if [ -z "$CI" ]; then
  sh ./.gemini/hooks/crg-update.sh 2>/dev/null &
fi

# AI post-commit summary — skip in CI or when SKIP_AI_REVIEW=1
if [ -z "$CI" ] && [ -z "$SKIP_AI_REVIEW" ] && command -v claude >/dev/null 2>&1; then
  DIFF=$(git diff HEAD~1 HEAD 2>/dev/null)
  if [ -n "$DIFF" ]; then
    echo "$DIFF" | claude --print "1-sentence summary of what changed. Note any follow-up needed." || true
  fi
fi

# AI metrics logging — append commit data to .ai-metrics/log.jsonl
# Methodology mirrors Cursor study (arxiv 2511.04427): track lines added/deleted per commit
# to measure real output vs subjective perception (Microsoft RCT arxiv 2410.18334).
if [ -z "$CI" ]; then
  HASH=$(git rev-parse HEAD 2>/dev/null)
  TS=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u +"%Y-%m-%dT%H:%M:%SZ")
  STATS=$(git diff HEAD~1 HEAD --shortstat 2>/dev/null || echo "")
  INS=$(echo "$STATS" | grep -o '[0-9]* insertion' | grep -o '[0-9]*' || echo "0")
  DEL=$(echo "$STATS" | grep -o '[0-9]* deletion' | grep -o '[0-9]*' || echo "0")
  FILES=$(echo "$STATS" | grep -o '[0-9]* file' | grep -o '[0-9]*' || echo "0")
  MSG=$(git log -1 --format="%s" 2>/dev/null || echo "")
  AI_ASSISTED="false"
  if git log -1 --format="%B" 2>/dev/null | grep -q "^AI-Session: true"; then
    AI_ASSISTED="true"
  fi
  INS=${INS:-0}; DEL=${DEL:-0}; FILES=${FILES:-0}
  LOG_DIR=".ai-metrics"
  mkdir -p "$LOG_DIR"
  printf '{"ts":"%s","hash":"%s","ai":%s,"ins":%s,"del":%s,"files":%s,"msg":"%s"}\n' \
    "$TS" "$HASH" "$AI_ASSISTED" "$INS" "$DEL" "$FILES" \
    "$(echo "$MSG" | head -c 80 | sed 's/"/\\"/g')" \
    >> "$LOG_DIR/log.jsonl" 2>/dev/null || true
fi
