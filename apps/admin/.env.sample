# admin (React + Rsbuild SPA) — copy to `.env` for local overrides.
# `.env` is git-ignored; this sample is safe to commit.
#
# Rsbuild only exposes variables prefixed with `PUBLIC_` to the browser bundle.

# Base URL of the backend serving ApiService (api-node or api-gateway).
PUBLIC_API_URL=http://localhost:3001

# Sentry error monitoring DSN (optional — leave empty to disable).
PUBLIC_SENTRY_DSN=

# The proto has no AuthService yet, so features/auth simulates login locally.
# true = accept any email + 6+ char password (local dev only).
# unset/false = refuse every login attempt — the safe default for any real
# deploy. See src/features/auth/adapters/auth.adapter.ts.
PUBLIC_ENABLE_MOCK_AUTH=true
