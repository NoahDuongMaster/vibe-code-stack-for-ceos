# Sentry DSN for the Astro landing app. Leave empty to disable Sentry.
# When set, astro.config.mjs wires the @sentry/astro integration (client-side
# error monitoring). Source-map upload is disabled, so no auth token is needed.
# Note: setting this turns the otherwise zero-JS landing page into a
# JS-shipping page — enable deliberately.
PUBLIC_SENTRY_DSN=

# Real production domain (e.g. https://example.com). Used for canonical URLs,
# OpenGraph tags, robots.txt and the sitemap. Falls back to a workers.dev URL
# if unset — set this before launch.
PUBLIC_SITE_URL=
