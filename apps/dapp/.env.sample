# Development defaults — safe to commit.
# For local secrets, create `.env.development.local` (git-ignored).

# --- Public (client-safe) ---
NEXT_PUBLIC_PROJECT_NAME="vibe-code-stack-for-ceos"
NEXT_PUBLIC_API_ENDPOINT=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_CORS_COOKIE=localhost
# Set to any non-empty value to enable extra client-side debug logging.
NEXT_PUBLIC_DEBUG=

# Sentry (optional in dev)
NEXT_PUBLIC_SENTRY_DSN=
# Only needed to upload source maps at build time (next.config.ts) — leave
# unset locally. Also requires a SENTRY_AUTH_TOKEN in the deploy environment.
SENTRY_ORG=
SENTRY_PROJECT=

# --- Server-only ---
# Dev-only placeholder — the app REFUSES to start with this exact value when
# NODE_ENV=production (see src/server/lib/session.ts). Generate a real secret
# for any real deploy: `openssl rand -base64 48`.
SESSION_SECRET=dev-session-secret-min-32-chars!!

# Reference credentials for the demo login flow (features/auth). See
# src/server/lib/auth.ts for where to swap this for a real IdP/backend check.
DEMO_AUTH_EMAIL=admin@example.com
DEMO_AUTH_PASSWORD=change-me-please

CORS_ORIGINS=*.localhost:3000,localhost:3000
CORS_RESOURCE=example.com
